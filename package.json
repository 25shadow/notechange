{
  "name": "notechange",
  "version": "1.0.0",
  "description": "在小米云笔记与 vivo 原子笔记之间迁移数据的本地桌面应用",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "dist:mac": "npm run build && electron-builder --mac --publish never",
    "dist:win": "npm run build && electron-builder --win --publish never",
    "release:mac": "node license-server/release.mjs mac",
    "release:win": "node license-server/release.mjs win",
    "license-server": "node license-server/start-admin.mjs",
    "admin:start": "node license-server/start-admin.mjs",
    "license:public-key": "node license-server/print-public-key.mjs",
    "license:keys": "node license-server/generate-keys.mjs",
    "setup:license": "node license-server/setup.mjs",
    "test": "vitest run --environment jsdom",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "build": {
    "appId": "com.notechange.app",
    "productName": "NoteChange",
    "icon": "resources/icon",
    "files": ["out/**", "package.json"],
    "mac": { "target": ["dmg", "zip"] },
    "win": { "target": ["nsis"] }
  },
  "dependencies": {
    "dompurify": "^3.4.12",
    "electron-updater": "^6.8.9",
    "fingerprint-generator": "^2.1.82",
    "fingerprint-injector": "^2.1.82",
    "jsdom": "^29.1.1",
    "lucide-react": "^1.24.0",
    "playwright": "^1.61.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "eslint": "^10.7.0",
    "prettier": "^3.9.5",
    "typescript": "^7.0.2",
    "vite": "^7.3.6",
    "vitest": "^4.1.10"
  }
}
